{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git restore*": "allow",
      "git stash*": "allow",
      "git branch*": "allow",
      "git checkout*": "allow"
    }
  }
}
