{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git add *": "allow",
      "git commit *": "allow",
      "git switch *": "allow",
      "git restore *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git push *": "deny",
      "git checkout *": "deny",
      "git reset *": "ask"
    }
  }
}
